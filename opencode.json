{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dbt": {
      "type": "local",
      "command": ["uvx", "dbt-mcp"],
      "enabled": true,
      "environment": {
        "DBT_PROJECT_DIR": ".",
        "DBT_PATH": "./.venv/bin/dbt"
      }
    },
    "snowflake": {
      "type": "local",
      "command": ["uvx", "snowflake-labs-mcp", "--service-config-file", ".mcp/snowflake_tools.yaml"],
      "enabled": true
    }
  }
}
